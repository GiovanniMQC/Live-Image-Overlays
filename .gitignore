# =========================
# Arquivos do Motor de TTS (Piper + RVC)
# =========================

# Ignora o ambiente virtual do Python (muito pesado e específico do seu PC)
tts/tts_env/

# Ignora os modelos de Inteligência Artificial (arquivos pesados de gigabytes)
tts/modelos_piper/
tts/modelos_rvc/
*.onnx
*.onnx.json
*.pth
*.index

# Ignora os áudios gerados temporariamente na live
*.wav
*.mp3

# =========================
# Bancos de Dados (estado local da aplicação)
# =========================
audio_db.json
media_db.json
tts_db.json

# =========================
# Mídia Customizada (uploads do usuário)
# =========================

# Imagens e vídeos enviados pelo painel admin
public/uploads/

# Áudios enviados pelo soundpad
public/audio_uploads/

# Áudios temporários gerados pelo pipeline RVC/TTS
public/rvc_temp/

# =========================
# Logs de execução
# =========================
.logs/

# =========================
# Sistema / Editores
# =========================
.DS_Store
Thumbs.db
*.swp
*.swo